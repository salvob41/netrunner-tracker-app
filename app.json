{
  "expo": {
    "name": "Trackster Taka - Netrunner",
    "slug": "netrunner-tracker",
    "version": "2.5.0",
    "orientation": "default",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./src/assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#07090d"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "io.github.salvob41.trackstertaka"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundImage": "./src/assets/adaptive-icon-background.png",
        "monochromeImage": "./src/assets/adaptive-icon-monochrome.png"
      },
      "package": "io.github.salvob41.trackstertaka",
      "versionCode": 2,
      "permissions": [
        "WAKE_LOCK",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./src/assets/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-asset",
      "expo-video"
    ]
  }
}
